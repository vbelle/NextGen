# Shared app password gating both the builder UI and chat runtime (Constitution: v1 access model).
NEXTGEN_APP_PASSWORD=change-me

# Fernet key encrypting credentials at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NEXTGEN_CREDENTIAL_KEY=

# Where the backend reaches Ollama. Defaults to the bundled docker-compose service;
# point elsewhere if your team already runs Ollama on shared hardware.
OLLAMA_BASE_URL=http://ollama:11434
